{
  "name": "soulpatch",
  "version": "0.1.0",
  "description": "Apply behavioral context patches from Claude's SOUL.md to other AI models",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "soulpatch": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "patches"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "llm",
    "system-prompt",
    "behavioral-guidelines",
    "opencode",
    "plugin"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0",
    "micromatch": "^4.0.8",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
